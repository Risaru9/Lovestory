# Supabase Configuration
# Salin file ini dan ubah namanya menjadi '.env.local' di folder 'app/'
# Kemudian masukkan kredensial proyek Supabase Anda.

# Project URL dari Settings -> API -> Project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key dari Settings -> API -> Project API keys (anon public)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
